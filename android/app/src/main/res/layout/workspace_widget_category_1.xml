<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/workspace_widget_category_1"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:layout_marginTop="8dp"
  android:background="#FFFFFF"
  android:orientation="vertical"
  android:padding="8dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/workspace_widget_category_title_1"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:textColor="#37352F"
      android:textSize="13sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/workspace_widget_category_add_1"
      android:layout_width="32dp"
      android:layout_height="32dp"
      android:background="#F6F5F4"
      android:gravity="center"
      android:textColor="#5645D4"
      android:textSize="20sp"
      android:textStyle="bold" />
  </LinearLayout>

  <TextView
    android:id="@+id/workspace_widget_category_notes_1"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:textColor="#5D5B54"
    android:textSize="12sp" />
</LinearLayout>
