<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="#FAFAF9"
  android:orientation="vertical"
  android:padding="12dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="Native Notes"
      android:textColor="#1A1A1A"
      android:textSize="16sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/workspace_widget_refresh_button"
      android:layout_width="36dp"
      android:layout_height="36dp"
      android:background="#EDE9E4"
      android:gravity="center"
      android:text="↻"
      android:textColor="#37352F"
      android:textSize="18sp" />

    <TextView
      android:id="@+id/workspace_widget_seek_button"
      android:layout_width="64dp"
      android:layout_height="36dp"
      android:layout_marginStart="8dp"
      android:background="#EDE9E4"
      android:gravity="center"
      android:text="SEEK"
      android:textColor="#37352F"
      android:textSize="12sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/workspace_widget_add_button"
      android:layout_width="36dp"
      android:layout_height="36dp"
      android:layout_marginStart="8dp"
      android:background="#5645D4"
      android:gravity="center"
      android:text="+"
      android:textColor="#FFFFFF"
      android:textSize="24sp"
      android:textStyle="bold" />
  </LinearLayout>

  <TextView
    android:id="@+id/workspace_widget_status"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:text="Loading workspace..."
    android:textColor="#787671"
    android:textSize="13sp" />

  <include layout="@layout/workspace_widget_category_1" />
  <include layout="@layout/workspace_widget_category_2" />
  <include layout="@layout/workspace_widget_category_3" />
  <include layout="@layout/workspace_widget_category_4" />
  <include layout="@layout/workspace_widget_category_5" />
</LinearLayout>
